# Release imzalama bilgileri. Bu dosyayı "key.properties" olarak kopyala
# ve kendi keystore bilgilerinle doldur. key.properties'i ASLA git'e commit etme.
#
# Keystore oluşturmak için (bir kez):
#   keytool -genkey -v -keystore upload-keystore.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# storeFile: android/app/build.gradle.kts içindeki file() android/app/'e görelidir.
# Keystore android/ altındaysa:  storeFile=../upload-keystore.jks
# Keystore android/app/ altındaysa: storeFile=upload-keystore.jks
#
# GitHub Actions (android-release.yml) secrets:
#   ANDROID_KEYSTORE_BASE64, ANDROID_KEYSTORE_PASSWORD,
#   ANDROID_KEY_PASSWORD, ANDROID_KEY_ALIAS
# Base64 (PowerShell):
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("upload-keystore.jks"))

storePassword=KEYSTORE_SIFRESI
keyPassword=ANAHTAR_SIFRESI
keyAlias=upload
storeFile=../upload-keystore.jks
