<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Push Notifications (FCM → APNs). İmzalama sırasında provisioning profile
	     Push Notifications yetkisini içermelidir; aksi halde FCM token alınamaz. -->
	<key>aps-environment</key>
	<string>production</string>
	<!-- Sign in with Apple (App Store 4.8: üçüncü taraf girişin yanında zorunlu).
	     App ID'de capability açık ve profil bunu içeriyor olmalı. -->
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>
</dict>
</plist>
